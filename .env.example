# Copy to .env and fill only providers used by your runfabric.yml.

# Optional framework controls
RUNFABRIC_STAGE=
RUNFABRIC_CLOUDFLARE_REAL_DEPLOY=0

# AWS Lambda
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=

# Google Cloud Functions
GCP_PROJECT_ID=
GCP_SERVICE_ACCOUNT_KEY=

# Azure Functions
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_SUBSCRIPTION_ID=
AZURE_RESOURCE_GROUP=

# Cloudflare Workers
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# Vercel
VERCEL_TOKEN=
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=

# Netlify
NETLIFY_AUTH_TOKEN=
NETLIFY_SITE_ID=

# Alibaba Function Compute
ALICLOUD_ACCESS_KEY_ID=
ALICLOUD_ACCESS_KEY_SECRET=
ALICLOUD_REGION=

# DigitalOcean Functions
DIGITALOCEAN_ACCESS_TOKEN=
DIGITALOCEAN_NAMESPACE=

# Fly Machines
FLY_API_TOKEN=
FLY_APP_NAME=

# IBM OpenWhisk
IBM_CLOUD_API_KEY=
IBM_CLOUD_REGION=
IBM_CLOUD_NAMESPACE=
