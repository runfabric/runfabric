{
  "name": "runfabric",
  "private": true,
  "version": "0.1.1",
  "packageManager": "pnpm@10.5.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "pnpm -r --if-present run build",
    "typecheck": "pnpm -r --if-present run typecheck",
    "lint": "pnpm -r --if-present run lint",
    "prepare": "husky",
    "lint-staged": "lint-staged",
    "check:syntax": "node scripts/check-syntax.mjs",
    "check:capabilities": "node scripts/sync-provider-capabilities.mjs --check",
    "check:docs-sync": "node scripts/check-docs-sync.mjs",
    "check:schema": "node scripts/check-schema-compat.mjs",
    "check:provider-contracts": "node scripts/check-provider-contracts.mjs",
    "check:compatibility": "npm run check:schema && npm run check:provider-contracts",
    "security:snyk:test": "npx --yes snyk test --all-projects --detection-depth=4 --severity-threshold=high",
    "security:snyk:monitor": "npx --yes snyk monitor --all-projects --detection-depth=4",
    "runfabric": "node --import ./tests/register-loader.mjs apps/cli/src/index.ts",
    "test": "tsx --tsconfig tsconfig.runtime.json --test tests/*.test.ts",
    "coverage": "node --experimental-test-coverage --test-coverage-lines=95 --test-coverage-functions=95 --test-coverage-branches=85 --test-coverage-exclude='**/dist/**' --test-coverage-exclude='**/*.cjs' --test-coverage-exclude='**/*.mjs' --test-coverage-exclude='tests/**' --test-coverage-exclude='packages/provider-*/src/**' --test-coverage-exclude='packages/core/src/state/**' --test-coverage-exclude='packages/core/src/provider-ops.ts' --test-coverage-exclude='packages/core/src/provider-ops/**' --test-coverage-exclude='apps/cli/src/commands/dev.ts' --test-coverage-exclude='apps/cli/src/commands/docs.ts' --test-coverage-exclude='apps/cli/src/commands/docs/**' --test-coverage-exclude='apps/cli/src/commands/call-local/**' --test-coverage-exclude='apps/cli/src/commands/state.ts' --test-coverage-exclude='apps/cli/src/commands/remove.ts' --test-coverage-exclude='apps/cli/src/commands/compose.ts' --test-coverage-exclude='apps/cli/src/commands/deploy.ts' --test-coverage-exclude='apps/cli/src/commands/deploy/**' --test-coverage-exclude='apps/cli/src/commands/doctor.ts' --test-coverage-exclude='apps/cli/src/commands/init.ts' --test-coverage-exclude='apps/cli/src/commands/init/prompt-raw.ts' --test-coverage-exclude='apps/cli/src/commands/init/prompt.ts' --test-coverage-exclude='apps/cli/src/commands/logs.ts' --test-coverage-exclude='apps/cli/src/commands/metrics.ts' --test-coverage-exclude='apps/cli/src/commands/migrate.ts' --test-coverage-exclude='apps/cli/src/commands/migrate/**' --test-coverage-exclude='apps/cli/src/commands/package.ts' --test-coverage-exclude='apps/cli/src/commands/plan.ts' --test-coverage-exclude='apps/cli/src/commands/traces.ts' --test-coverage-exclude='apps/cli/src/providers/registry.ts' --test-coverage-exclude='apps/cli/src/utils/compose.ts' --test-coverage-exclude='apps/cli/src/utils/project-functions.ts' --test-coverage-exclude='packages/core/src/hooks.ts' --test-coverage-exclude='packages/core/src/provider.ts' --test-coverage-exclude='packages/core/src/state.ts' --test-coverage-exclude='packages/planner/src/parse-config.ts' --test-coverage-exclude='packages/planner/src/parse-config/**' --test-coverage-exclude='packages/planner/src/planner.ts' --test-coverage-exclude='packages/planner/src/portability.ts' --test-coverage-exclude='packages/runtime-node/src/fly-http-adapter.ts' --test-coverage-exclude='packages/runtime-node/src/framework-wrappers.ts' --import tsx --test tests/*.test.ts",
    "release:check": "npm run check:syntax && npm run check:capabilities && npm run check:docs-sync && npm run check:compatibility && npm test && pnpm -r --if-present run build && pnpm -r --if-present run typecheck",
    "release:notes:create": "node scripts/release/create-release-notes.mjs",
    "release:notes:verify": "node scripts/release/verify-release-notes.mjs",
    "release:notes:sign": "node scripts/release/sign-release-notes.mjs",
    "release:publish": "node scripts/release/publish-packages.mjs",
    "release:publish:dry-run": "node scripts/release/publish-packages.mjs --dry-run",
    "release:publish:beta": "node scripts/release/publish-packages.mjs --tag beta",
    "release:publish:beta:dry-run": "node scripts/release/publish-packages.mjs --tag beta --dry-run",
    "release:verify:published": "node scripts/release/verify-published-release.mjs",
    "release:pack:cli": "pnpm --filter @runfabric/cli pack --pack-destination ./.artifacts",
    "link:cli": "NODE_NO_WARNINGS=1 corepack pnpm --filter @runfabric/core --filter @runfabric/planner --filter @runfabric/builder --filter @runfabric/runtime-node --filter @runfabric/cli --if-present run build && PNPM_HOME=\"${PNPM_HOME:-${HOME:-$PWD}/.pnpm}\" && mkdir -p \"$PNPM_HOME\" && export PNPM_HOME && export PATH=\"$PNPM_HOME:$PATH\" && NODE_NO_WARNINGS=1 corepack pnpm -r --filter @runfabric/cli exec pnpm link --global --global-dir \"$PNPM_HOME/global\" --config.global-bin-dir=\"$PNPM_HOME\"",
    "unlink:cli": "PNPM_HOME=\"${PNPM_HOME:-${HOME:-$PWD}/.pnpm}\" && export PNPM_HOME && export PATH=\"$PNPM_HOME:$PATH\" && NODE_NO_WARNINGS=1 corepack pnpm -r --filter @runfabric/cli exec pnpm unlink --global --global-dir \"$PNPM_HOME/global\" --config.global-bin-dir=\"$PNPM_HOME\"",
    "test:all": "pnpm -r --if-present run test",
    "clean": "pnpm -r --if-present run clean"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/runfabric/runfabric.git"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  },
  "lint-staged": {
    "*": [
      "npm run check:syntax"
    ]
  },
  "pnpm": {
    "overrides": {
      "@tootallnate/once": "3.0.1"
    }
  },
  "homepage": "https://github.com/runfabric/runfabric#readme",
  "bugs": {
    "url": "https://github.com/runfabric/runfabric/issues"
  }
}
