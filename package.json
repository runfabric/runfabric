{
  "name": "runfabric-monorepo",
  "private": true,
  "description": "RunFabric multi-provider serverless framework — root workspace",
  "scripts": {
    "build": "make build",
    "build:go": "go build -trimpath -ldflags \"-s -w\" -o bin/runfabric ./cmd/runfabric",
    "test": "make test",
    "test:go": "go test ./...",
    "release:check": "make release-check",
    "release:check:go": "go build ./... && go test ./...",
    "version": "make version",
    "clean": "make clean",
    "lint": "make lint"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": ["serverless", "runfabric", "cli", "multi-provider"],
  "license": "MIT"
}
