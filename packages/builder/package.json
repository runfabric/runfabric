{
  "name": "@runfabric/builder",
  "version": "0.1.1",
  "private": false,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "tsc --noEmit -p tsconfig.json",
    "test": "tsc --noEmit -p tsconfig.json",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@runfabric/core": "workspace:*",
    "@runfabric/planner": "workspace:*",
    "typescript": "^5.9.2"
  },
  "description": "Artifact packaging pipeline for runfabric providers",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/runfabric/runfabric.git",
    "directory": "packages/builder"
  },
  "keywords": [
    "runfabric",
    "serverless",
    "functions",
    "builder",
    "artifacts"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://github.com/runfabric/runfabric/tree/main/packages/builder#readme",
  "bugs": {
    "url": "https://github.com/runfabric/runfabric/issues"
  }
}