{
  "name": "@runfabric/core",
  "version": "0.1.0-beta.3",
  "private": false,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "tsc --noEmit -p tsconfig.json",
    "test": "tsc --noEmit -p tsconfig.json",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.901.0",
    "@azure/storage-blob": "^12.28.0",
    "@google-cloud/storage": "^7.17.1",
    "pg": "^8.16.3"
  },
  "description": "Core contracts and shared types for runfabric",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/runfabric/runfabric.git",
    "directory": "packages/core"
  },
  "keywords": [
    "runfabric",
    "serverless",
    "functions",
    "core",
    "types"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  }
