# Registry server
REGISTRY_CONFIG=
REGISTRY_LISTEN=127.0.0.1:8787
REGISTRY_WEB_DIR=./web/dist
REGISTRY_UI_AUTH_URL=https://auth.runfabric.cloud/device
REGISTRY_UI_DOCS_URL=https://runfabric.cloud/docs
REGISTRY_DB_PATH=./data/registry.db.json
REGISTRY_UPLOADS_DIR=./data/uploads
REGISTRY_METADATA_PROVIDER=json
REGISTRY_SEED_LOCAL_DEV_DATA=false

# Metadata backend (required when REGISTRY_METADATA_PROVIDER=postgres)
REGISTRY_POSTGRES_DSN=
REGISTRY_POSTGRES_DRIVER=pgx

# Metadata backend (required when REGISTRY_METADATA_PROVIDER=mongodb)
REGISTRY_MONGODB_URI=
REGISTRY_MONGODB_DATABASE=runfabric_registry

# Cache
REGISTRY_REDIS_ADDR=

# Auth + policy
REGISTRY_ALLOW_ANONYMOUS_READ=true
REGISTRY_ARTIFACT_SIGNING_SECRET=change-me
REGISTRY_OIDC_ISSUER=https://auth.runfabric.cloud
REGISTRY_OIDC_AUDIENCE=registry
REGISTRY_OIDC_JWKS_URL=https://auth.runfabric.cloud/.well-known/jwks.json
REGISTRY_OIDC_SUBJECT_CLAIM=sub
REGISTRY_OIDC_TENANT_CLAIM=tenant_id
REGISTRY_OIDC_ROLES_CLAIM=roles
REGISTRY_OIDC_ROLE_MODES=roles,realm_access.roles,resource_access.<client>.roles,scope
REGISTRY_OIDC_ROLE_CLIENT_ID=registry
REGISTRY_OIDC_AUDIENCE_MODE=exact
REGISTRY_OIDC_ALLOWED_JWT_ALGS=RS256,ES256
REGISTRY_CASBIN_POLICY=internal/adapter/policy/casbin/policy.csv

# Optional artifact URL mode (S3/S3-compatible)
REGISTRY_S3_BASE_URL=
REGISTRY_S3_BUCKET=
REGISTRY_S3_REGION=
REGISTRY_S3_ENDPOINT=
REGISTRY_S3_ACCESS_KEY_ID=
REGISTRY_S3_SECRET_ACCESS_KEY=
REGISTRY_S3_SESSION_TOKEN=
