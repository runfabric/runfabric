{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://registry.runfabric.cloud/schema/error.v1.json",
  "title": "RunFabric Registry Error (v1)",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "error": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "code": { "type": "string", "minLength": 1 },
        "message": { "type": "string", "minLength": 1 },
        "details": { "type": "object" },
        "hint": { "type": "string" },
        "docsUrl": { "type": "string" },
        "requestId": { "type": "string", "minLength": 1 }
      },
      "required": ["code", "message", "requestId"]
    }
  },
  "required": ["error"]
}

