{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://runfabric.dev/schemas/resource.schema.json",
  "title": "Resource",
  "description": "RunFabric resource definition (e.g. queues, buckets, topics). May be used under a top-level resources key in runfabric.yml.",
  "type": "object",
  "properties": {
    "type": { "type": "string", "description": "Resource type (e.g. queue, bucket, topic)." },
    "properties": { "type": "object", "description": "Type-specific properties." }
  },
  "additionalProperties": true
}
