{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://runfabric.dev/schemas/workflow.schema.json",
  "title": "RunFabric Workflow Definition",
  "description": "Definition for one entry under runfabric.yml workflows.",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "description": "Workflow name."
    },
    "steps": {
      "type": "array",
      "description": "Ordered workflow steps.",
      "items": {
        "$ref": "#/$defs/WorkflowStep"
      }
    }
  },
  "required": ["name"],
  "additionalProperties": false,
  "$defs": {
    "WorkflowStep": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "description": "Explicit step identifier."
        },
        "function": {
          "type": "string",
          "minLength": 1,
          "description": "Step identifier and legacy function field."
        },
        "kind": {
          "type": "string",
          "enum": ["code", "ai-retrieval", "ai-generate", "ai-structured", "ai-eval", "human-approval"],
          "description": "Workflow step kind."
        },
        "model": {
          "type": "string",
          "minLength": 1,
          "description": "Optional per-step model override for AI step kinds."
        },
        "timeout": {
          "type": "integer",
          "minimum": 0,
          "description": "Per-step timeout in seconds."
        },
        "input": {
          "type": "object",
          "description": "Kind-specific step input (prompt/query/schema/score/mcp/approval payload).",
          "additionalProperties": true
        },
        "next": {
          "type": "string",
          "description": "Optional next step identifier or branch label."
        },
        "retry": {
          "$ref": "#/$defs/WorkflowRetry"
        }
      },
      "additionalProperties": false
    },
    "WorkflowRetry": {
      "type": "object",
      "properties": {
        "attempts": {
          "type": "integer",
          "minimum": 1
        },
        "backoffSeconds": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    }
  }
}
