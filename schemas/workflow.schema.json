{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://runfabric.dev/schemas/workflow.schema.json",
  "title": "Workflow",
  "description": "RunFabric workflow definition. May be used under a top-level workflows key in runfabric.yml.",
  "type": "object",
  "properties": {
    "name": { "type": "string" },
    "steps": { "type": "array", "items": { "type": "object" } }
  },
  "additionalProperties": true
}
